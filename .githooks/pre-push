#!/bin/sh
# Rebuild Vue SPA only when client source files changed in the commits being pushed.
# If a rebuild is needed, it commits the new build and aborts the push so the
# build commit is included when the user runs git push again.

z40=0000000000000000000000000000000000000000
needs_build=0

while read local_ref local_sha remote_ref remote_sha; do
    [ "$local_sha" = "$z40" ] && continue  # skip branch deletions

    if [ "$remote_sha" = "$z40" ]; then
        # New branch — check all files across commits being pushed
        changed=$(git log --name-only --format="" "$local_sha" | grep -E '^client/(src/|index\.html|vite\.config|package\.json|package-lock\.json)')
    else
        # Existing branch — check diff between remote and local
        changed=$(git diff --name-only "$remote_sha" "$local_sha" | grep -E '^client/(src/|index\.html|vite\.config|package\.json|package-lock\.json)')
    fi

    if [ -n "$changed" ]; then
        needs_build=1
        break
    fi
done

if [ "$needs_build" = "1" ]; then
    echo "→ Client source changed — rebuilding Vue SPA..."

    (cd client && npm run build)
    if [ $? -ne 0 ]; then
        echo "✗ Vue SPA build failed. Push aborted."
        exit 1
    fi

    git add -A webroot/spa/

    if ! git diff --cached --quiet; then
        git commit -m "chore: rebuild Vue SPA"
        echo ""
        echo "✓ Vue SPA rebuilt and committed."
        echo "  Run 'git push' again to include the build commit."
        echo ""
        exit 1
    else
        echo "✓ Vue SPA already up to date."
    fi
fi

echo "==> PHP CodeSniffer (cs-check)..."
composer cs-check
if [ $? -ne 0 ]; then
    echo ""
    echo "✗ CS check failed. Run 'composer cs-fix' to auto-fix, then try again."
    exit 1
fi

echo "==> PHPStan..."
php -d memory_limit=512M vendor/bin/phpstan analyse --no-progress
if [ $? -ne 0 ]; then
    echo ""
    echo "✗ PHPStan failed. Fix the errors above before pushing."
    exit 1
fi

echo "==> PHPUnit tests..."
composer test
if [ $? -ne 0 ]; then
    echo ""
    echo "✗ Tests failed. Fix failing tests before pushing."
    exit 1
fi

echo "✓ All pre-push checks passed!"
